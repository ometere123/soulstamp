# Copy to .env and fill in the contract address after deploying

# Contract address after running: genlayer deploy contracts/soul_stamp.py
# (Targets GenLayer Studionet — make sure your MetaMask is switched to it via client.connect())
VITE_CONTRACT_ADDRESS=0x80e1EDb6996483E7050bb81B4D1a54dD69879719

# Cloudflare Worker backend base URL, without /api at the end.
# Example: https://soulstamp-discord.your-cloudflare-subdomain.workers.dev
VITE_DISCORD_BACKEND_URL=https://soulstamp-discord.your-cloudflare-subdomain.workers.dev
